# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Local dev (matches the dev_postgres podman container):
DATABASE_URL=postgresql://dev:devpass@127.0.0.1:5432/devdb

# Production (set via k8s Secret / envsubst — see k8s/postgres.yaml):
# DATABASE_URL=postgresql://inforganizer:<POSTGRES_PASSWORD>@postgres:5432/inforganizer

# Set to "true" only when connecting to a managed RDS / Cloud SQL instance
# that requires TLS (rejectUnauthorized is disabled for self-signed certs).
DATABASE_SSL=false

# ─── Auth ─────────────────────────────────────────────────────────────────────
# CHANGE THIS in production — use a long, random string (e.g. openssl rand -hex 32).
# Production value is injected from the k8s Secret (postgres-secret → JWT_SECRET).
JWT_SECRET=inforganizer-dev-secret-CHANGE-IN-PRODUCTION

# JWT token lifetime (any value accepted by jsonwebtoken, e.g. 7d, 24h, 1h).
JWT_EXPIRES=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development


# ─── AWS (for production) ─────────────────────────────────────────────────────
AWS_REGION=
ECR_REPOSITORY=